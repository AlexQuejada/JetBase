{
    "services": [
        {
            "name": "backend",
            "rootDir": "backend",
            "buildCommand": "pip install -r requirements.txt",
            "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT"
        },
        {
            "name": "frontend",
            "rootDir": "frontend",
            "buildCommand": "npm install --legacy-peer-deps && npm run build",
            "startCommand": "npx serve -s build -l $PORT"
        }
    ]
}